{
  "manifest_version": 3,
  "name": "GigCraft AI",
  "version": "1.0.0",
  "description": "AI-powered writing assistant for Fiverr gig drafts.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.fiverr.com/*"],
      "js": ["assets/content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  }
}
